generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  /// scrypt hash: "saltHex:keyHex" — never expose to clients
  passwordHash     String?
  name             String?
  avatarUrl        String?
  listingLikes    ListingLike[]
  guestConversations Conversation[] @relation("ConversationGuest")
  hostConversations  Conversation[] @relation("ConversationHost")
  sentMessages      Message[]
  role             UserRole  @default(GUEST)
  /// Short intro shown on profile
  bio              String?
  /// Shown as “My work: …”
  work             String?
  /// Extra profile prompts (Airbnb-style grid), string map
  profileAnswers   Json?
  showTravelStamps Boolean   @default(true)
  /// Set when a platform admin suspends the account; blocks sign-in and API access.
  bannedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  listings         Listing[]
  bookings         Booking[]
  reviews          Review[]
}

model Listing {
  id            String      @id @default(cuid())
  hostId        String
  title         String
  description   String
  stayType      StayType
  status        ListingStatus @default(INCOMPLETE)
  /// Guest-facing area (e.g. "San Francisco, CA") — not full street
  location      String
  country       String
  /// Exact address (host-only workflow; use for verification)
  streetLine1   String        @default("")
  streetLine2   String        @default("")
  city          String        @default("")
  stateRegion   String        @default("")
  postalCode    String        @default("")
  latitude      Float
  longitude     Float
  pricePerNight Int
  weekdayPrice  Int         @default(100)
  weekendPrice  Int         @default(120)
  maxGuests     Int         @default(2)
  bedrooms      Int         @default(1)
  beds          Int         @default(1)
  bathrooms     Float       @default(1)
  imageUrl             String
  imageUrls            String[]    @default([])
  /// Guest favorites: Wifi, TV, Kitchen, etc.
  guestFavorites       String[]
  /// Standout amenities: Pool, Hot tub, Patio, etc.
  standoutAmenities    String[]
  /// Safety: smoke alarm, first aid, etc.
  safetyAmenities      String[]
  hostLanguages        String[]
  likes               ListingLike[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  host          User        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  reviews       Review[]
  conversations Conversation[]
}

model ListingLike {
  id         String   @id @default(cuid())
  userId     String
  listingId  String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Booking {
  id         String        @id @default(cuid())
  userId     String
  listingId  String
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  totalPrice Int
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  conversation Conversation?
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  listingId  String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

enum ConversationKind {
  BOOKING
  ADMIN_SUPPORT
}

model Conversation {
  id        String            @id @default(cuid())
  kind      ConversationKind  @default(BOOKING)
  bookingId String?           @unique
  listingId String?

  guestId String
  hostId  String

  /// When kind is ADMIN_SUPPORT: same as guestId (non-admin user); unique per user.
  adminThreadForUserId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guest    User      @relation("ConversationGuest", fields: [guestId], references: [id], onDelete: Cascade)
  host     User      @relation("ConversationHost", fields: [hostId], references: [id], onDelete: Cascade)

  messages Message[]
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime  @default(now())
  /// When set, recipients have opened the thread and this message was marked read.
  readAt         DateTime?
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum UserRole {
  HOST
  GUEST
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  PAID
  CANCELLED
  COMPLETED
}

enum StayType {
  HOTEL_ROOM
  BNB_ROOM
  RENTAL_ROOM
}

enum ListingStatus {
  INCOMPLETE
  PUBLISHED
  UNPUBLISHED
}
