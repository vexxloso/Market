# Copy to .env and replace every CHANGE_ME / YOUR_*

DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE?schema=public"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE?schema=public"

ADMIN_EMAIL="admin@example.com"

JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_32"

# Scheme + host only, no trailing slash, no path (path goes in NEXT_PUBLIC_BASE_PATH)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Empty if app is at /. Set /market if Nginx serves this app under /market
NEXT_PUBLIC_BASE_PATH=

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Stripe: keys saved in Admin → Stripe keys (PlatformConfig) are used first; env below is fallback.
# Secret must be sk_test_... / sk_live_... — never pk_...
STRIPE_SECRET_KEY=
# Optional — pk_... only if you add Stripe.js on the client; not used by default (hosted Checkout).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret: local dev = `stripe listen` output; deployed = Dashboard → Webhooks → Signing secret.
# DB (Admin) takes precedence over STRIPE_WEBHOOK_SECRET when both are set.
STRIPE_WEBHOOK_SECRET=

# Windows dev — if you see EBUSY on .next renames, set this (and exclude that folder from Defender sync).
# Or use an absolute path on a local disk: NEXT_DIST_DIR=C:/Temp/myapp-next-dev
# NEXT_DIST_DIR=.next-local
